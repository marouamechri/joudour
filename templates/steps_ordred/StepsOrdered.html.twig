<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}{% endblock %}
		</title>

		{% block stylesheets %}
			{{ encore_entry_link_tags('app') }}
			<link rel="stylesheet" href="{{ asset('css/stepDelevred.css')}}"/>
		{% endblock %}


	</head>
	<body>
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-lg-12  text-center p-0 mt-3 mb-2">
					<ul id="progressbar">
						<li class="active" id="step1">
							<strong>Livraison
							</strong>
						</li>
						<li id="step2">
							<strong>Facturation
							</strong>
						</li>
						<li id="step3">
							<strong>Paiement</strong>
						</li>
						<li id="step4">
							<strong>Terminer</strong>
						</li>
					</ul>
				</div>
			</div>
			<div class="row">
				<div class="col-lg-6  mt-5 ">
					{{ form_start(form) }}
					<div class="page bg-light p-2" id="page1">
						<h2 class="text-center">Livraison</h2>
						<div class="blok 50">
							<div>{{ form_row(form.nom)}}</div>
							<div>{{ form_row(form.prenom)}}</div>
						</div>
						{{ form_row(form.street)}}
						<div class="blok">{{ form_row(form.number)}}
							{{ form_row(form.apartement)}}</div>
						{{ form_row(form.message)}}
						{{ form_row(form.country_code)}}
						{{ form_row(form.city)}}
						<div class="text-center">
							<button class="btn btn-dark" type="button" name="next-step" class="next-step">Suivant</button>
						</div>
					</div>
					<div class="page bg-light mt-5" id="page2">
						<h2 class="text-center">Facturation</h2>
						{{ form_row(form.email)}}
						{{ form_row(form.tel)}}
						<div class="text-center">
							<button class="btn btn-dark" type="button" name="next-step" class="next-step">Suivant</button>
						</div>
					</div>
					<div class="page bg-light mt-5" id="page3"></div>
						<h2 class="text-center">Paiement</h2>
					<div class="page bg-light mt-5" id="page4"></div>
					{{ form_end(form) }}

				</div>
				<div class="col-lg-6 p-3">{{ include('steps_ordred/_order.html.twig') }}</div>

			</div>
		</div>

		{# <div class="px-0 pt-4 pb-0 mt-3 mb-3">
