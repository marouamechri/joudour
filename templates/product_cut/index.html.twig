{% extends 'baseAdmin.html.twig' %}

{% block title %}ProductCut index{% endblock %}

{% block body %}
    <h1>ProductCut index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for product_cut in product_cuts %}
            <tr>
                <td>{{ product_cut.id }}</td>
                <td>
                    <a href="{{ path('app_product_cut_show', {'id': product_cut.id}) }}">show</a>
                    <a href="{{ path('app_product_cut_edit', {'id': product_cut.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="2">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_product_cut_new') }}">Create new</a>
{% endblock %}
