{% extends 'baseAdmin.html.twig' %}

{% block title %}Color{% endblock %}

{% block body %}
    <h1>Color</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ color.id }}</td>
            </tr>
            <tr>
                <th>RefColor</th>
                <td>{{ color.refColor }}</td>
            </tr>
            <tr>
                <th>NameColor</th>
                <td>{{ color.nameColor }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_color_index') }}">back to list</a>

    <a href="{{ path('app_color_edit', {'id': color.id}) }}">edit</a>

    {{ include('colors/_delete_form.html.twig') }}
{% endblock %}
